# =============================================================================
# apps/api/.env.example — plantilla de variables del backend.
# Cópiala como `.env` y rellena con credenciales reales:
#   cp .env.example .env
# =============================================================================

PORT=3001

# ---------- Azure Document Intelligence (OCR / prebuilt-layout) --------------
AZURE_DI_ENDPOINT="https://<tu-recurso>.cognitiveservices.azure.com"
AZURE_DI_KEY="<tu-clave-di>"
AZURE_DI_API_VERSION="2024-11-30"
AZURE_DI_MODEL="prebuilt-layout"

# ---------- Azure OpenAI (validación visión + extracción) --------------------
AZURE_OPENAI_ENDPOINT="https://<tu-recurso>.openai.azure.com"
AZURE_OPENAI_KEY="<tu-clave-openai>"
AZURE_OPENAI_DEPLOYMENT="<nombre-del-deployment>"
AZURE_OPENAI_API_VERSION="2025-04-01-preview"
AZURE_OPENAI_MAX_TOKENS="1500"
AZURE_OPENAI_TEMPERATURE="0"

# ---------- DocuWare (archivado documental, vía gateway Comfama) -------------
COMFAMA_DOCUWARE_URL="https://integracionesqa.comfama.com/tran/TRA-SC-GestionDocumentos/api/documento/almacenardocumentobytearray"
COMFAMA_DOCUWARE_APIKEY="<apikey-docuware>"
COMFAMA_DOCUWARE_ARCHIVADOR_ID="<guid-del-archivador>"

# ---------- Comfama (tokenizer JWT + CECOs + SAP) ----------------------------
COMFAMA_TOKENIZER_URL="https://integracionesqa.comfama.com/tokenizer/accessToken"
COMFAMA_TOKENIZER_APIKEY="<apikey-tokenizer>"
COMFAMA_ORIGIN="https://qa.comfama.com"
COMFAMA_CECOS_URL="https://integraciones.comfama.com/tran/TRA-TRA-CentrosCostos/get_cecos_textSet"
COMFAMA_CECOS_APIKEY="<apikey-cecos>"
# SAP puede usar su propio tokenizer (p.ej. QA) independiente del de CECOs (p.ej. PROD).
COMFAMA_SAP_TOKENIZER_URL="https://integracionesqa.comfama.com/tokenizer/accessToken"
COMFAMA_SAP_TOKENIZER_APIKEY="<apikey-tokenizer-sap>"
COMFAMA_SAP_ORIGIN="https://qa.comfama.com"
COMFAMA_SAP_URL="https://integracionesqa.comfama.com/tran/TRA-FIN-ContabilizacionLegados/FI/Contabilizacion"
COMFAMA_SAP_APIKEY="<apikey-sap>"
COMFAMA_ID_FUENTE="POWER_CM"
