{
  "name": "viatigo-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo de legalización de gastos: frontend Vite (apps/web) + backend Express (apps/api).",
  "type": "module",
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "prepare": "lefthook install && git config commit.template .gitmessage",
    "dev": "concurrently -n api,web -c green,blue \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "build": "npm --workspace apps/api run build && npm --workspace apps/web run build",
    "build:web": "npm --workspace apps/web run build",
    "build:api": "npm --workspace apps/api run build",
    "typecheck": "npm --workspace apps/api run typecheck && npm --workspace apps/web run typecheck",
    "start:api": "npm --workspace apps/api run start",
    "lint": "npm --workspace apps/web run lint"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "concurrently": "^9.1.0",
    "lefthook": "^2.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
